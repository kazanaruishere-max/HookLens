# ==============================
# HookLens Environment Variables
# ==============================

# --- Frontend (.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_AI=true

# --- Backend (Cloudflare Workers) ---
JWT_SECRET=your_jwt_secret_here_min_32_chars
ENCRYPTION_KEY=your_32_byte_hex_key_here

# Database (Supabase)
DATABASE_URL=postgresql://postgres:password@localhost:5432/hooklens

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# OpenRouter (AI)
OPENROUTER_API_KEY=sk-or-v1-your_key

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# Resend (Email)
RESEND_API_KEY=re_your_key

# --- WebSocket Server ---
WS_PORT=3001
WS_REDIS_URL=redis://localhost:6379
WS_JWT_SECRET=your_jwt_secret_here_min_32_chars
WS_FRONTEND_URL=http://localhost:3000
